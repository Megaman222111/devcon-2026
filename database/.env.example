# Leave DB_HOST blank when running on Kaggle — the app falls back to SQLite.
DB_HOST=database-1.cfc84ock4e6y.us-west-2.rds.amazonaws.com
DB_PORT=5432
DB_SECRET_ARN=arn:aws:secretsmanager:us-west-2:440744249877:secret:rds!db-74baf849-1877-4fc9-9ffe-c2e19bda8aaa-UQDnpv
DB_CONN_MAX_AGE=60
DB_SSL_MODE=verify-full
DB_SSL_ROOT_CERT=global-bundle.pem

# --- AI inference (optional overrides) ---
# All three default to small, T4-friendly models — only set these to swap.
# TRANSLATION_MODEL=facebook/nllb-200-distilled-600M
# PDF_CHAT_MODEL=Qwen/Qwen2.5-3B-Instruct
# KEYWORD_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Truncate PDFs longer than this many characters before feeding the LLM.
# PDF_CHAT_MAX_CHARS=60000
# PDF_CHAT_MAX_NEW_TOKENS=512

# CORS — leave both unset to allow any origin (handy behind cloudflared).
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ALLOW_ALL_ORIGINS=False
